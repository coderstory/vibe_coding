<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.coderstory.springboot.mapper.KnowledgeArticleMapper">
    
    <resultMap id="BaseResultMap" type="cn.coderstory.springboot.entity.KnowledgeArticle">
        <id column="id" property="id"/>
        <result column="category_id" property="categoryId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="view_count" property="viewCount"/>
        <result column="deleted" property="deleted"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <select id="searchArticles" resultMap="BaseResultMap">
        SELECT id, category_id, title, content, status, view_count, deleted, create_time
        FROM knowledge_article
        WHERE deleted = 0
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND MATCH(title, content) AGAINST(#{keyword} IN NATURAL LANGUAGE MODE)
        </if>
        ORDER BY create_time DESC
    </select>
    
</mapper>
